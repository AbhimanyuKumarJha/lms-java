{
  "info": {
    "_postman_id": "1df38b0d-6c42-4f2e-b3a0-c1123b0299e7",
    "name": "LMS Modular Monolith API",
    "description": "Ready-to-use requests for the LMS Spring Boot modular monolith. Import this collection with the LMS Local environment.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{name}}\",\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/auth/signup",
            "description": "Creates an unverified user, generates an OTP, stores it in Redis, and publishes a signup OTP event."
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"otp\": \"{{otp}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/otp/verify",
            "description": "Copy the generated OTP from your configured notification path into the environment variable named otp before sending."
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": {{userId}},\n  \"name\": \"{{name}}\",\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/users",
            "description": "Internal/library-member style user creation. For public signup, prefer Auth > Signup."
          }
        },
        {
          "name": "Get Users",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/users"
          }
        },
        {
          "name": "Get User Issued Books",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/users/{{userId}}/issued-books"
          }
        },
        {
          "name": "Get User Fine",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/users/{{userId}}/fine"
          }
        }
      ]
    },
    {
      "name": "Book Copies",
      "item": [
        {
          "name": "Create Book Copy",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bookCopyId\": {{bookCopyId}},\n  \"title\": \"{{bookTitle}}\",\n  \"author\": \"{{bookAuthor}}\",\n  \"description\": \"{{bookDescription}}\",\n  \"copyCode\": \"{{copyCode}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/book-copies"
          }
        },
        {
          "name": "Get Book Copies",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/book-copies"
          }
        },
        {
          "name": "Get Total Copies",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/book-copies/titles/{{bookTitlePath}}/copies/total"
          }
        },
        {
          "name": "Get Available Copies",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/book-copies/titles/{{bookTitlePath}}/copies/available"
          }
        }
      ]
    },
    {
      "name": "Issues",
      "item": [
        {
          "name": "Create Issue",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"transactionId\": {{transactionId}},\n  \"userId\": {{userId}},\n  \"bookCopyId\": {{bookCopyId}}\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/issues"
          }
        },
        {
          "name": "Create Issues Bulk",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "[\n  {\n    \"transactionId\": {{transactionId}},\n    \"userId\": {{userId}},\n    \"bookCopyId\": {{bookCopyId}}\n  }\n]",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/issues/bulk"
          }
        },
        {
          "name": "Return Book",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/issues/{{transactionId}}/return"
          }
        },
        {
          "name": "Get Issues",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/issues"
          }
        }
      ]
    }
  ]
}
