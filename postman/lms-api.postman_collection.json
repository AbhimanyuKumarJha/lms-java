{
  "info": {
    "_postman_id": "1df38b0d-6c42-4f2e-b3a0-c1123b0299e7",
    "name": "LMS Modular Monolith API",
    "description": "Ready-to-use requests for the LMS Spring Boot modular monolith. Import this collection with the LMS Local environment.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Signup returns success', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "if (pm.response.code >= 200 && pm.response.code < 300) {",
                  "  const body = pm.response.json();",
                  "  if (body.userId) pm.environment.set('userId', body.userId);",
                  "  if (body.email) pm.environment.set('email', body.email);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{name}}\",\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/auth/signup",
            "description": "Creates an unverified user and prints the OTP in the Spring Boot terminal through the notification listener."
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"otp\": \"{{otp}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/otp/verify",
            "description": "Copy the OTP from the Spring Boot terminal into the environment variable named otp before sending."
          }
        }
      ]
    },
